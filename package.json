    "@types/jest": "29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-native-worklets": "0.5.1",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
