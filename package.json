{
  "name": "medride",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "npx playwright test --headed",
    "test:e2e:headless": "npx playwright test"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
